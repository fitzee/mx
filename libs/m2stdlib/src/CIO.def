DEFINITION MODULE FOR "C" CIO;
(* C I/O functions used by native M2 stdlib modules *)
FROM SYSTEM IMPORT ADDRESS;

PROCEDURE getchar(): INTEGER;
PROCEDURE putchar(c: INTEGER): INTEGER;
PROCEDURE scanf(fmt: ADDRESS): INTEGER;
PROCEDURE fopen(path: ADDRESS; mode: ADDRESS): ADDRESS;
PROCEDURE fclose(f: ADDRESS): INTEGER;
PROCEDURE fgetc(f: ADDRESS): INTEGER;
PROCEDURE fputc(c: INTEGER; f: ADDRESS): INTEGER;
PROCEDURE fread(buf: ADDRESS; size: CARDINAL; count: CARDINAL; f: ADDRESS): CARDINAL;
PROCEDURE fwrite(buf: ADDRESS; size: CARDINAL; count: CARDINAL; f: ADDRESS): CARDINAL;
PROCEDURE fseek(f: ADDRESS; offset: INTEGER; whence: INTEGER): INTEGER;
PROCEDURE ftell(f: ADDRESS): INTEGER;
PROCEDURE feof(f: ADDRESS): INTEGER;
PROCEDURE fprintf(f: ADDRESS; fmt: ADDRESS): INTEGER;

END CIO.
