IMPLEMENTATION MODULE Storage;
FROM SYSTEM IMPORT ADDRESS;
FROM CMem IMPORT malloc, free;

PROCEDURE ALLOCATE(VAR p: ADDRESS; size: CARDINAL);
BEGIN
    p := malloc(size)
END ALLOCATE;

PROCEDURE DEALLOCATE(VAR p: ADDRESS; size: CARDINAL);
BEGIN
    free(p);
    p := NIL
END DEALLOCATE;

END Storage.
