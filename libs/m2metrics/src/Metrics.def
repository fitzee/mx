DEFINITION MODULE Metrics;

(* Cross-platform system metrics: load average, memory, process stats.
   Single call, no configuration, no external dependencies. *)

TYPE
  SysSnapshot = RECORD
    load1:      LONGINT;   (* 1-min load avg × 1000  *)
    load5:      LONGINT;   (* 5-min load avg × 1000  *)
    load15:     LONGINT;   (* 15-min load avg × 1000 *)
    memTotalMB: LONGINT;   (* total physical RAM (MB) *)
    memFreeMB:  LONGINT;   (* free + inactive RAM (MB) *)
    cpuUserUs:  LONGINT;   (* user CPU time (µs)      *)
    cpuSysUs:   LONGINT;   (* system CPU time (µs)    *)
    rssKB:      LONGINT;   (* current RSS (KB)        *)
    maxRssKB:   LONGINT;   (* peak RSS (KB)           *)
  END;

(* Fill snap with current system metrics. *)
PROCEDURE Snapshot(VAR snap: SysSnapshot);

END Metrics.
