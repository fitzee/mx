DEFINITION MODULE Http2Frame;
(* HTTP/2 frame encoding and decoding.

   Encodes/decodes the 9-byte frame header and payload for
   SETTINGS, PING, GOAWAY, WINDOW_UPDATE, and RST_STREAM frames.

   Uses m2Codec Reader/Writer for binary I/O over ByteBuf types.
   No heap allocation. *)

FROM ByteBuf IMPORT BytesView, Buf;
FROM Http2Types IMPORT FrameHeader, Settings;

(* ── Frame header ──────────────────────────────────────── *)

(* Decode a 9-byte frame header from a BytesView.
   Returns ok=FALSE if fewer than 9 bytes available. *)
PROCEDURE DecodeHeader(v: BytesView; VAR hdr: FrameHeader;
                       VAR ok: BOOLEAN);

(* Encode a 9-byte frame header into a Buf. *)
PROCEDURE EncodeHeader(VAR b: Buf; hdr: FrameHeader);

(* ── Connection preface ────────────────────────────────── *)

(* Write the 24-byte HTTP/2 client connection preface. *)
PROCEDURE WritePreface(VAR b: Buf);

(* Check if the first 24 bytes of v match the connection preface.
   Returns FALSE if v is too short or doesn't match. *)
PROCEDURE CheckPreface(v: BytesView): BOOLEAN;

(* ── SETTINGS frame ────────────────────────────────────── *)

(* Decode a SETTINGS frame payload into a Settings record.
   payloadLen must be a multiple of 6.
   Updates only the settings that appear in the payload. *)
PROCEDURE DecodeSettings(payload: BytesView;
                         VAR s: Settings; VAR ok: BOOLEAN);

(* Encode a full SETTINGS frame (header + payload) for the
   six standard settings.  Writes 9 + 36 = 45 bytes. *)
PROCEDURE EncodeSettings(VAR b: Buf; s: Settings);

(* Encode a SETTINGS ACK frame (header only, 0 payload). *)
PROCEDURE EncodeSettingsAck(VAR b: Buf);

(* ── PING frame ────────────────────────────────────────── *)

(* Encode a PING frame with 8 bytes of opaque data. *)
PROCEDURE EncodePing(VAR b: Buf; data: BytesView; isAck: BOOLEAN);

(* ── GOAWAY frame ──────────────────────────────────────── *)

(* Encode a GOAWAY frame. *)
PROCEDURE EncodeGoaway(VAR b: Buf; lastStreamId: CARDINAL;
                       errorCode: CARDINAL);

(* Decode a GOAWAY frame payload.
   Extracts lastStreamId and errorCode. *)
PROCEDURE DecodeGoaway(payload: BytesView;
                       VAR lastStreamId: CARDINAL;
                       VAR errorCode: CARDINAL;
                       VAR ok: BOOLEAN);

(* ── WINDOW_UPDATE frame ───────────────────────────────── *)

(* Encode a WINDOW_UPDATE frame. *)
PROCEDURE EncodeWindowUpdate(VAR b: Buf; streamId: CARDINAL;
                             increment: CARDINAL);

(* Decode a WINDOW_UPDATE payload (4 bytes). *)
PROCEDURE DecodeWindowUpdate(payload: BytesView;
                             VAR increment: CARDINAL;
                             VAR ok: BOOLEAN);

(* ── RST_STREAM frame ─────────────────────────────────── *)

(* Encode a RST_STREAM frame. *)
PROCEDURE EncodeRstStream(VAR b: Buf; streamId: CARDINAL;
                          errorCode: CARDINAL);

(* Decode a RST_STREAM payload (4 bytes). *)
PROCEDURE DecodeRstStream(payload: BytesView;
                          VAR errorCode: CARDINAL;
                          VAR ok: BOOLEAN);

(* ── DATA frame ────────────────────────────────────────── *)

(* Encode a DATA frame header.  Caller appends payload bytes. *)
PROCEDURE EncodeDataHeader(VAR b: Buf; streamId: CARDINAL;
                           payloadLen: CARDINAL; endStream: BOOLEAN);

(* ── HEADERS frame ─────────────────────────────────────── *)

(* Encode a HEADERS frame header.  Caller appends header block. *)
PROCEDURE EncodeHeadersHeader(VAR b: Buf; streamId: CARDINAL;
                              payloadLen: CARDINAL;
                              endStream: BOOLEAN;
                              endHeaders: BOOLEAN);

END Http2Frame.
