DEFINITION MODULE DNS;

  (* Minimal async DNS resolver.
     Returns a Future that resolves with an AddrRec.

     Current limitation: getaddrinfo is called synchronously.
     The returned Future is already settled on return.  This
     preserves the Futures-first API so callers need no changes
     when a truly asynchronous backend is added later.

     IPv4 only (first A record). *)

  FROM SYSTEM IMPORT ADDRESS, BYTE;
  FROM EventLoop IMPORT Loop;
  FROM Scheduler IMPORT Scheduler;
  FROM Promise IMPORT Future;

  TYPE
    AddrRec = RECORD
      addrV4 : ARRAY [0..3] OF BYTE;
      port   : INTEGER;
    END;

    AddrPtr = POINTER TO AddrRec;

    Status = (OK, Invalid, ResolveFailed, OutOfMemory);

  (* Resolve hostname to IPv4 address (synchronous).
     Post: outFuture resolves with Value.ptr -> heap AddrRec.
     Caller must DEALLOCATE the AddrRec when done.
     Blocks during resolution. *)
  PROCEDURE ResolveA(lp: Loop; sched: Scheduler;
                     VAR host: ARRAY OF CHAR;
                     port: INTEGER;
                     VAR outFuture: Future): Status;

  (* Resolve hostname to IPv4 address (asynchronous).
     Spawns a background pthread for DNS resolution.
     The returned Future is pending until the background thread
     completes, at which point it is resolved or rejected.

     Post: outFuture resolves with Value.ptr -> heap AddrRec.
     Caller must DEALLOCATE the AddrRec when done.

     IMPORTANT: The callback is invoked from a background thread.
     Callers must use thread-safe mechanisms to deliver the result
     to the event loop thread (e.g. a notification pipe). *)
  PROCEDURE ResolveAsync(lp: Loop; sched: Scheduler;
                         VAR host: ARRAY OF CHAR;
                         port: INTEGER;
                         VAR outFuture: Future): Status;

END DNS.
