PROCEDURE StoreResult(key: ARRAY OF CHAR; artifactPath: ARRAY OF CHAR): INTEGER;
PROCEDURE LookupResult(key: ARRAY OF CHAR; destPath: ARRAY OF CHAR): INTEGER;

END Cache.
