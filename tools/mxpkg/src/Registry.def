DEFINITION MODULE Registry;

EXCEPTION RegistryError;

(* Initialize registry directory (~/.mxpkg/registry/) *)
PROCEDURE Init;

(* Publish current package to local registry *)
PROCEDURE Publish;

(* Lookup a package version in the registry index.
   Returns 0 if found, -1 if not found.
   Sets sha256 hex in shaBuf. *)
PROCEDURE Lookup(name: ARRAY OF CHAR; version: ARRAY OF CHAR;
                 VAR shaBuf: ARRAY OF CHAR): INTEGER;

(* Fetch a package from registry to cache.
   Sets resolved path in pathBuf. RAISEs on failure. *)
PROCEDURE Fetch(name: ARRAY OF CHAR; version: ARRAY OF CHAR;
                VAR pathBuf: ARRAY OF CHAR);

(* Verify a cached package against its registry sha256.
   Returns 0 if valid, -1 if mismatch or missing. *)
PROCEDURE Verify(name: ARRAY OF CHAR; version: ARRAY OF CHAR): INTEGER;

(* Lookup a package by name and semver range spec.
   Scans all versions in index/<name>/, picks latest matching.
   Returns 0 on success, sets resolvedVersion and sha. *)
PROCEDURE LookupRange(name: ARRAY OF CHAR; rangeSpec: ARRAY OF CHAR;
                      VAR resolvedVersion: ARRAY OF CHAR;
                      VAR shaBuf: ARRAY OF CHAR): INTEGER;

(* Check if a specific version is already published.
   Returns 1 if exists, 0 if not. *)
PROCEDURE VersionExists(name: ARRAY OF CHAR; version: ARRAY OF CHAR): INTEGER;

(* Get the latest published version of a package.
   Returns 0 on success with version in latestBuf, -1 if no versions. *)
PROCEDURE GetLatestVersion(name: ARRAY OF CHAR; VAR latestBuf: ARRAY OF CHAR): INTEGER;

(* Fetch a package from a remote HTTP registry.
   Sets resolved path in pathBuf. RAISEs on failure. *)
PROCEDURE FetchRemote(url: ARRAY OF CHAR; name: ARRAY OF CHAR;
                      version: ARRAY OF CHAR; VAR pathBuf: ARRAY OF CHAR);

(* Fetch the latest version of a package from a remote registry.
   Queries <url>/api/v1/packages/<name>/latest for JSON with version + sha256.
   Returns 0 on success, -1 on failure. *)
PROCEDURE FetchLatest(url: ARRAY OF CHAR; name: ARRAY OF CHAR;
                      VAR verBuf: ARRAY OF CHAR;
                      VAR shaBuf: ARRAY OF CHAR): INTEGER;

(* Publish current package to a remote HTTP registry.
   Token is the Bearer token for authentication. *)
PROCEDURE PublishRemote(url: ARRAY OF CHAR; token: ARRAY OF CHAR);

(* Fetch list of all versions from a remote registry.
   Writes newline-separated versions into verListBuf.
   Returns count of versions found, 0 on failure. *)
PROCEDURE FetchVersions(url: ARRAY OF CHAR; name: ARRAY OF CHAR;
                        VAR verListBuf: ARRAY OF CHAR): INTEGER;

(* Resolve a semver range against a remote registry.
   Returns 0 on success, -1 on failure.
   Sets resolvedVer and sha on success. *)
PROCEDURE ResolveRangeRemote(url: ARRAY OF CHAR; name: ARRAY OF CHAR;
                             rangeSpec: ARRAY OF CHAR;
                             VAR resolvedVer: ARRAY OF CHAR;
                             VAR sha: ARRAY OF CHAR): INTEGER;

(* Search packages on a remote registry by query term. *)
PROCEDURE SearchRemote(url: ARRAY OF CHAR; query: ARRAY OF CHAR);

(* Set insecure mode (skip TLS verification). *)
PROCEDURE SetInsecure(mode: BOOLEAN);

END Registry.
