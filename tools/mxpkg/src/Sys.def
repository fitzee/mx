DEFINITION MODULE FOR "C" Sys;
FROM SYSTEM IMPORT ADDRESS;

(* File I/O — handle-based *)
PROCEDURE m2sys_fopen(path: ADDRESS; mode: ADDRESS): INTEGER;
PROCEDURE m2sys_fclose(handle: INTEGER): INTEGER;
PROCEDURE m2sys_fread_line(handle: INTEGER; buf: ADDRESS; bufSize: INTEGER): INTEGER;
PROCEDURE m2sys_fwrite_str(handle: INTEGER; data: ADDRESS): INTEGER;
PROCEDURE m2sys_fwrite_bytes(handle: INTEGER; data: ADDRESS; len: INTEGER): INTEGER;
PROCEDURE m2sys_fread_bytes(handle: INTEGER; buf: ADDRESS; maxLen: INTEGER): INTEGER;

(* File system queries *)
PROCEDURE m2sys_file_exists(path: ADDRESS): INTEGER;
PROCEDURE m2sys_is_dir(path: ADDRESS): INTEGER;
PROCEDURE m2sys_mkdir_p(path: ADDRESS): INTEGER;
PROCEDURE m2sys_remove_file(path: ADDRESS): INTEGER;

(* Process execution *)
PROCEDURE m2sys_exec(cmdline: ADDRESS): INTEGER;
PROCEDURE m2sys_exit(code: INTEGER);

(* SHA-256: hex_out must be >= 65 chars *)
PROCEDURE m2sys_sha256_str(data: ADDRESS; len: INTEGER; hexOut: ADDRESS);

(* Paths & environment *)
PROCEDURE m2sys_join_path(a: ADDRESS; b: ADDRESS; outBuf: ADDRESS; outSize: INTEGER);
PROCEDURE m2sys_home_dir(outBuf: ADDRESS; outSize: INTEGER);
PROCEDURE m2sys_getcwd(outBuf: ADDRESS; outSize: INTEGER);
PROCEDURE m2sys_chdir(path: ADDRESS): INTEGER;
PROCEDURE m2sys_getenv(name: ADDRESS; outBuf: ADDRESS; outSize: INTEGER);

(* String length *)
PROCEDURE m2sys_strlen(s: ADDRESS): INTEGER;

(* File operations *)
PROCEDURE m2sys_sha256_file(path: ADDRESS; hexOut: ADDRESS): INTEGER;
PROCEDURE m2sys_file_size(path: ADDRESS): LONGINT;
PROCEDURE m2sys_copy_file(src: ADDRESS; dst: ADDRESS): INTEGER;
PROCEDURE m2sys_rename(oldPath: ADDRESS; newPath: ADDRESS): INTEGER;

(* Directory listing *)
PROCEDURE m2sys_list_dir(dir: ADDRESS; buf: ADDRESS; bufSize: INTEGER): INTEGER;

(* Path utilities *)
PROCEDURE m2sys_basename(path: ADDRESS; outBuf: ADDRESS; outSize: INTEGER);
PROCEDURE m2sys_dirname(path: ADDRESS; outBuf: ADDRESS; outSize: INTEGER);

(* Process execution (captures stdout) *)
PROCEDURE m2sys_exec_output(cmdline: ADDRESS; outBuf: ADDRESS; outSize: INTEGER): INTEGER;

(* Tar *)
PROCEDURE m2sys_tar_create(archivePath: ADDRESS; baseDir: ADDRESS): INTEGER;
PROCEDURE m2sys_tar_create_ex(archivePath: ADDRESS; baseDir: ADDRESS; excludePattern: ADDRESS): INTEGER;
PROCEDURE m2sys_tar_extract(archivePath: ADDRESS; destDir: ADDRESS): INTEGER;

(* File locking *)
PROCEDURE m2sys_flock(handle: INTEGER; exclusive: INTEGER): INTEGER;
PROCEDURE m2sys_funlock(handle: INTEGER): INTEGER;

(* Remove directory recursively *)
PROCEDURE m2sys_rmdir_r(path: ADDRESS): INTEGER;

(* Time — returns Unix timestamp in seconds *)
PROCEDURE m2sys_unix_time(): LONGINT;

(* File metadata *)
PROCEDURE m2sys_file_mtime(path: ADDRESS): LONGINT;
PROCEDURE m2sys_is_symlink(path: ADDRESS): INTEGER;

END Sys.
